---
import Base from '../../layouts/Base.astro'
import { client, queries, urlFor } from '../../lib/sanity'
import { PortableText } from '@portabletext/react'

export async function getStaticPaths() {
  const posts = await client.fetch(queries.allPosts)
  return posts.map((post: any) => ({ params: { slug: post.slug.current } }))
}

const { slug } = Astro.params
const post = await client.fetch(queries.postBySlug, { slug })

if (!post) return Astro.redirect('/writing')

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null

const ogImage = post.coverImage?.asset ? urlFor(post.coverImage).width(1200).height(630).url() : undefined
---

<Base title={post.title} description={post.excerpt} ogImage={ogImage}>
  <article class="max-w-2xl mx-auto px-6 py-16">
    <div class="mb-10">
      {post.tags?.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.tags.map((tag: any) => (
            <a
              href={`/writing/tag/${tag.slug.current}`}
              class="text-xs text-stone-500 tracking-wide uppercase hover:text-stone-900 transition-colors"
            >
              {tag.title}
            </a>
          ))}
        </div>
      )}

      <h1 class="text-3xl font-semibold tracking-tight leading-tight mb-4">{post.title}</h1>

      <div class="flex items-center gap-3 text-sm text-stone-400">
        {post.author?.name && (
          <span>{post.author.name}</span>
        )}
        {date && (
          <>
            <span>·</span>
            <time datetime={post.publishedAt}>{date}</time>
          </>
        )}
      </div>
    </div>

    {post.coverImage?.asset && (
      <div class="mb-12 rounded-lg overflow-hidden aspect-[16/9] bg-stone-100">
        <img
          src={urlFor(post.coverImage).width(1200).height(675).url()}
          alt={post.coverImage.alt || post.title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <div class="prose prose-stone prose-lg max-w-none
      prose-headings:font-semibold prose-headings:tracking-tight
      prose-a:text-stone-900 prose-a:underline prose-a:decoration-stone-300 prose-a:underline-offset-2
      hover:prose-a:decoration-stone-900
      prose-code:text-sm prose-code:bg-stone-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-stone-900 prose-pre:text-stone-100
      prose-blockquote:border-stone-300 prose-blockquote:text-stone-600 prose-blockquote:not-italic
      prose-img:rounded-lg">
      {post.body && <PortableText value={post.body} client:load />}
    </div>

    <div class="mt-16 pt-8 border-t border-stone-200">
      <a href="/writing" class="text-sm text-stone-400 hover:text-stone-900 transition-colors">
        ← All posts
      </a>
    </div>
  </article>
</Base>
