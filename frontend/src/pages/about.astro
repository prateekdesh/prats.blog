---
import Base from '../layouts/Base.astro'
---

<Base title="About">
  <div class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-2xl font-semibold tracking-tight mb-8">About</h1>
    <div class="prose prose-stone prose-lg max-w-none dark:prose-invert
      prose-headings:font-semibold prose-headings:tracking-tight
      prose-a:text-stone-900 prose-a:underline prose-a:decoration-stone-300
      hover:prose-a:decoration-stone-900
      dark:prose-a:text-stone-100 dark:prose-a:decoration-stone-700">
      <p>
        Hi, I'm Prateek. I write about building software, startups, and whatever else I'm thinking about.
      </p>
      <p>
        You can find me on <a href="https://twitter.com/prateekdesh19">Twitter</a>.
      </p>
       <p>
        More about me on <a href="https://prateekdeshmukh.com">my website</a>.
      </p>
    </div>
  </div>
</Base>
