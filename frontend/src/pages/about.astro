---
import Base from '../layouts/Base.astro'
---

<Base title="About">
  <div class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-2xl font-semibold tracking-tight mb-8">About</h1>
    <div class="prose prose-stone prose-lg max-w-none
      prose-headings:font-semibold prose-headings:tracking-tight
      prose-a:text-stone-900 prose-a:underline prose-a:decoration-stone-300
      hover:prose-a:decoration-stone-900">
      <p>
        Hi, I'm Prateek. I write about building software, investing, and whatever else I'm thinking about.
      </p>
      <p>
        You can find me on <a href="https://twitter.com/prateekdeshmukh">Twitter</a>.
      </p>
    </div>
  </div>
</Base>
